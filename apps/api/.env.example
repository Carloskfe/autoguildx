# App
PORT=3001
NODE_ENV=development

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5433/autoguildx

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=7d

# Firebase Admin (for Auth)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Stripe (Payments)
# Get these from https://dashboard.stripe.com/test/apikeys and the webhook section
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create recurring products in Stripe and paste the price IDs here
STRIPE_PRICE_OWNER=price_...
STRIPE_PRICE_COMPANY=price_...

# AWS S3 (Media Storage)
# Leave blank to use stub mode (placeholder images, no real uploads)
# Bucket policy: grant s3:PutObject to the IAM user; enable CORS for PUT from the frontend origin
# CORS rule: AllowedOrigins=[FRONTEND_URL], AllowedMethods=[PUT], AllowedHeaders=[Content-Type]
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
# Optional: CloudFront or custom domain in front of S3 (defaults to https://{bucket}.s3.{region}.amazonaws.com)
AWS_S3_PUBLIC_URL=

# CORS — set to your production frontend URL
FRONTEND_URL=http://localhost:3000

# Throttle
THROTTLE_TTL=60
THROTTLE_LIMIT=100
